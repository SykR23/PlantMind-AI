# ==========================
# LLM
# ==========================
LLM_PROVIDER=groq
LLM_MODEL=llama-3.3-70b-versatile
TEMPERATURE=0.2
GROQ_API_KEY=YOUR_API_KEY

# ==========================
# Embeddings
# ==========================
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
DEVICE=cpu

# ==========================
# Retrieval
# ==========================
SEARCH_TYPE=similarity
TOP_K=3
FETCH_K=10

# ==========================
# Chunking
# ==========================
CHUNK_SIZE=500
CHUNK_OVERLAP=100